{
  "name": "switchboard",
  "productName": "Switchboard",
  "version": "1.0.0",
  "description": "A self-hosted Tailscale share manager with multi-user access control — publish local folders to your tailnet or the public internet (Funnel), with per-user view/manage permissions, password-protected shares, QR codes, and a live hit dashboard.",
  "author": "sasha-thecornerspore-dev",
  "license": "MIT",
  "main": "main.js",
  "homepage": "https://github.com/sasha-thecornerspore-dev/switchboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/sasha-thecornerspore-dev/switchboard.git"
  },
  "scripts": {
    "start": "electron .",
    "service": "node src/switchboard.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.thecornerspore.switchboard",
    "productName": "Switchboard",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      { "from": "src", "to": "service" },
      { "from": "assets/switchboard.ico", "to": "switchboard.ico" }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Switchboard"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Network",
      "icon": "build/icon.png"
    }
  }
}
